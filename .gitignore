# Bug Hunter Pro - Vulnerability Scanner
# Ignore patterns for security and development files

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
ENV/
.venv

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs and reports
*.log
scanner.log
reports/
*.json
*.html
*.pdf

# Configuration files with sensitive data
config.yaml
.env
.env.local
secrets.yaml

# API keys and credentials
*.key
*.pem
*.crt
api_keys.txt

# Test coverage
.coverage
htmlcov/
.pytest_cache/
.tox/

# Package distribution
dist/
build/
*.egg-info/
wheels/

# macOS files
.DS_Store
.AppleDouble
.LSOverride

# Windows files
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux files
*~
.directory

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Database files
*.db
*.sqlite
*.sqlite3

# Screenshot and media
screenshots/
*.png
*.jpg
*.jpeg
*.gif

# Backup files
*.bak
*.backup
*~
